# Copy this file to `.env` and fill in real values.
# `.env` is in .gitignore — never commit real secrets.

# OpenAI — required for ingestion (gpt-4o-mini) and embeddings
# (text-embedding-3-small, 1536-dim; must match db/init.sql vector column).
OPENAI_API_KEY=sk-proj-...

# Postgres with the pgvector extension. See db/init.sql for schema.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/freelancer_analyzer

# Layer 3 session retention (reserved — sessions table not yet wired up in code).
SESSION_RETENTION_DAYS=30
